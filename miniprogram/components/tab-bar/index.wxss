.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-top: 1rpx solid rgba(224, 237, 226, 0.6);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 110rpx;
  padding: 0 40rpx;
}

/* === 每个 tab === */
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 8rpx 0 4rpx;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 6rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #A8BFA9;
  font-weight: 500;
  transition: color 0.25s ease;
}

.tab-item.active .tab-text {
  color: #5B9A6F;
  font-weight: 600;
}

/* 选中指示点 */
.tab-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #5B9A6F;
  margin-top: 6rpx;
  animation: dotIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* === 历史图标 === */
.icon-calendar {
  width: 42rpx;
  height: 42rpx;
  display: flex;
  flex-direction: column;
}

.cal-top {
  height: 12rpx;
  background: #C8D8CA;
  border-radius: 6rpx 6rpx 0 0;
  position: relative;
}

.cal-top::before,
.cal-top::after {
  content: '';
  position: absolute;
  top: -4rpx;
  width: 4rpx;
  height: 10rpx;
  background: #C8D8CA;
  border-radius: 2rpx;
}

.cal-top::before { left: 14rpx; }
.cal-top::after { right: 14rpx; }

.tab-item.active .cal-top {
  background: #5B9A6F;
}

.tab-item.active .cal-top::before,
.tab-item.active .cal-top::after {
  background: #5B9A6F;
}

.cal-body {
  flex: 1;
  border: 3rpx solid #C8D8CA;
  border-top: none;
  border-radius: 0 0 8rpx 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item.active .cal-body {
  border-color: #5B9A6F;
}

.cal-text {
  font-size: 18rpx;
  color: #C8D8CA;
  font-weight: 700;
}

.tab-item.active .cal-text {
  color: #5B9A6F;
}

/* === 主页图标（居中突出） === */
.tab-item.center {
  transform: translateY(-6rpx);
}

.home-icon {
  width: 56rpx;
  height: 56rpx;
}

.home-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #EEF5EF;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.home-circle.active {
  background: linear-gradient(135deg, #5B9A6F, #7AB88E);
  box-shadow: 0 6rpx 20rpx rgba(91, 154, 111, 0.3);
}

.home-svg {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.h-roof {
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 12rpx solid #A8BFA9;
}

.home-circle.active .h-roof {
  border-bottom-color: #fff;
}

.h-body {
  width: 20rpx;
  height: 12rpx;
  background: #A8BFA9;
  border-radius: 0 0 3rpx 3rpx;
  margin-top: 2rpx;
}

.home-circle.active .h-body {
  background: rgba(255, 255, 255, 0.85);
}

.h-door {
  width: 8rpx;
  height: 8rpx;
  background: #A8BFA9;
  border-radius: 3rpx 3rpx 0 0;
  margin-top: 2rpx;
}

.home-circle.active .h-door {
  background: rgba(255, 255, 255, 0.6);
}

/* === 用户图标 === */
.icon-user {
  width: 42rpx;
  height: 42rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.u-head {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #C8D8CA;
}

.tab-item.active .u-head {
  background: #5B9A6F;
}

.u-body {
  width: 28rpx;
  height: 14rpx;
  background: #C8D8CA;
  border-radius: 14rpx 14rpx 0 0;
  margin-top: 4rpx;
}

.tab-item.active .u-body {
  background: #5B9A6F;
}

/* === 动画 === */
@keyframes dotIn {
  from {
    transform: scale(0);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}
