.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(91, 154, 111, 0.08);
  transition: all 0.3s ease;
}

.badge-item:active {
  transform: scale(0.96);
}

.badge-item.locked {
  opacity: 0.5;
  filter: grayscale(100%);
}

.badge-icon-wrapper {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.badge-glow {
  position: absolute;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(232, 184, 109, 0.3) 0%, transparent 70%);
  border-radius: 50%;
  animation: glow 2s ease-in-out infinite;
}

.badge-icon {
  font-size: 48rpx;
  z-index: 1;
}

.badge-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #2C3E2D;
  text-align: center;
  margin-bottom: 4rpx;
}

.badge-desc {
  font-size: 20rpx;
  color: #7A8F7C;
  text-align: center;
  line-height: 1.4;
}

@keyframes glow {
  0%, 100% {
    transform: scale(1);
    opacity: 0.5;
  }
  50% {
    transform: scale(1.2);
    opacity: 0.8;
  }
}
