.quote-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.quote-modal.show {
  visibility: visible;
  opacity: 1;
}

.mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.modal-card {
  position: relative;
  width: 92%;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  padding: 60rpx 40rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow-y: auto;
}

.modal-card.card-show {
  transform: translateY(0);
}

.close-btn {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 50%;
}

.close-icon {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

/* 成就提示 */
.achievement-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFF8E1, #FFECB3);
  padding: 20rpx 30rpx;
  border-radius: 20rpx;
  margin-bottom: 40rpx;
  animation: fadeInUp 0.5s ease 0.2s both;
}

.achievement-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.achievement-text {
  font-size: 26rpx;
  color: #E8B86D;
  font-weight: 600;
}

/* 语录区域 */
.quote-section {
  padding: 20rpx 0;
  animation: fadeInUp 0.5s ease 0.3s both;
}

.quote-mark {
  font-size: 120rpx;
  line-height: 1;
  color: rgba(91, 154, 111, 0.15);
  font-family: Georgia, serif;
  margin-bottom: -30rpx;
}

.quote-content {
  padding: 0 20rpx;
}

.quote-text {
  font-size: 36rpx;
  color: #2C3E2D;
  line-height: 1.8;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.quote-author {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-top: 30rpx;
  padding-right: 20rpx;
}

.author-line {
  width: 40rpx;
  height: 2rpx;
  background: #5B9A6F;
  margin-right: 16rpx;
}

.author-name {
  font-size: 26rpx;
  color: #7A8F7C;
  font-style: italic;
}

/* 统计区域 */
.stats-section {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  margin: 30rpx 0;
  background: linear-gradient(135deg, #F5F9F7, #E8F5E9);
  border-radius: 24rpx;
  animation: fadeInUp 0.5s ease 0.4s both;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 50rpx;
}

.stat-number {
  font-size: 64rpx;
  font-weight: 700;
  color: #5B9A6F;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: #7A8F7C;
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(91, 154, 111, 0.2);
}

/* 操作按钮 */
.action-section {
  display: flex;
  gap: 24rpx;
  margin-top: 30rpx;
  animation: fadeInUp 0.5s ease 0.5s both;
}

.btn-share,
.btn-poster {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  line-height: 1.5;
}

.btn-share {
  background: linear-gradient(135deg, #5B9A6F, #8BC4A0);
  color: #fff;
}

.btn-share::after {
  display: none;
}

.btn-poster {
  background: rgba(91, 154, 111, 0.1);
  color: #5B9A6F;
}

.btn-poster::after {
  display: none;
}

.share-icon,
.poster-icon {
  margin-right: 10rpx;
  font-size: 30rpx;
}

/* 滑动提示 */
.swipe-hint {
  text-align: center;
  padding: 20rpx 0 10rpx;
  animation: fadeIn 1s ease 1s both;
}

.hint-text {
  font-size: 22rpx;
  color: #ccc;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
