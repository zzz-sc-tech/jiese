@import "../../styles/theme.wxss";

.page-timer {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F5F9F7 30%, #F5F9F7 100%);
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* 目标信息 */
.timer-goal-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(91, 154, 111, 0.08);
}

.tgi-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tgi-icon {
  font-size: 32rpx;
}

.tgi-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E2D;
}

.tgi-today {
  font-size: 24rpx;
  color: #5B9A6F;
  background: rgba(91, 154, 111, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

/* 模式切换 */
.timer-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.timer-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.timer-tab.active {
  border-color: #5B9A6F;
  background: rgba(91, 154, 111, 0.05);
}

.tab-icon {
  font-size: 28rpx;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #2C3E2D;
}

/* 计时器显示区域 */
.timer-display {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 环形进度 - 番茄钟 */
.ring-container {
  position: relative;
  width: 480rpx;
  height: 480rpx;
  margin-bottom: 40rpx;
  flex-shrink: 0;
}

.timer-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  border-radius: 50%;
  border: 24rpx solid #5B9A6F;
  background: transparent;
  box-shadow: 0 8rpx 28rpx rgba(91, 154, 111, 0.12);
}

.ring-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.timer-time {
  font-size: 80rpx;
  font-weight: 700;
  color: #2C3E2D;
  letter-spacing: 4rpx;
}

.timer-phase {
  font-size: 26rpx;
  color: #5B9A6F;
  margin-top: 8rpx;
}

/* 番茄计数 */
.pomodoro-count {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.pc-label {
  font-size: 24rpx;
  color: #7A8F7C;
}

.pc-dots {
  display: flex;
  gap: 12rpx;
}

.pc-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #E8F5E9;
  transition: all 0.3s ease;
}

.pc-dot.done {
  background: #E88D67;
  box-shadow: 0 0 0 4rpx rgba(232, 141, 103, 0.2);
}

.pc-num {
  font-size: 24rpx;
  color: #7A8F7C;
}

/* 阶段切换提示 */
.phase-hint {
  text-align: center;
  margin: 20rpx 0;
  animation: pulse 1.5s ease-in-out infinite;
}

.hint-text {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* 数字时钟 - 学习时钟 */
.clock-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 60rpx 0;
}

.clock-time {
  font-size: 100rpx;
  font-weight: 700;
  color: #2C3E2D;
  letter-spacing: 6rpx;
  font-variant-numeric: tabular-nums;
}

.clock-state {
  font-size: 28rpx;
  color: #5B9A6F;
  margin-top: 16rpx;
}

/* 控制按钮 */
.timer-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 40rpx;
}

.ctrl-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.ctrl-btn:active {
  transform: scale(0.9);
}

.ctrl-btn.primary {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #5B9A6F, #8BC4A0);
  box-shadow: 0 8rpx 24rpx rgba(91, 154, 111, 0.3);
}

.ctrl-btn.primary.pause {
  background: linear-gradient(135deg, #E8B86D, #F5D89A);
  box-shadow: 0 8rpx 24rpx rgba(232, 184, 109, 0.3);
}

.ctrl-btn.secondary {
  width: 100rpx;
  height: 100rpx;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.ctrl-icon {
  font-size: 36rpx;
}

.ctrl-btn.primary .ctrl-icon {
  font-size: 44rpx;
}

.ctrl-label {
  font-size: 20rpx;
  color: #7A8F7C;
  margin-top: 4rpx;
}

.ctrl-btn.primary .ctrl-label {
  color: #fff;
}

/* 番茄钟设置 */
.timer-settings {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.setting-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.setting-label {
  font-size: 22rpx;
  color: #7A8F7C;
  margin-bottom: 12rpx;
}

.setting-value-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.setting-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F5F9F7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #5B9A6F;
  font-weight: 700;
}

.setting-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E2D;
  min-width: 80rpx;
  text-align: center;
}

/* 今日会话记录 */
.session-list {
  width: 100%;
  margin-top: 24rpx;
}

.session-title {
  font-size: 26rpx;
  color: #7A8F7C;
  margin-bottom: 16rpx;
  display: block;
}

.session-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.session-time {
  font-size: 28rpx;
  font-weight: 500;
  color: #2C3E2D;
}

/* 震动提示弹窗 */
.vibrate-alert-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.vibrate-alert-modal {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 80rpx;
  background: var(--color-bg-card);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.3);
  animation: bounceIn 0.3s ease;
}

.vibrate-alert-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  animation: shake 0.3s ease infinite alternate;
}

.vibrate-alert-text {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.vibrate-alert-hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

@keyframes bounceIn {
  0% { transform: scale(0.8); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes shake {
  0% { transform: rotate(-10deg); }
  100% { transform: rotate(10deg); }
}

.session-type {
  font-size: 24rpx;
}
