@import "../../styles/theme.wxss";

.page-diary {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 24rpx;
}

.diary-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.diary-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
}

.diary-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.diary-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.diary-item {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  box-shadow: var(--shadow-sm);
}

.diary-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.diary-content {
  flex: 1;
}

.diary-text {
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.6;
  margin-bottom: 8rpx;
  display: block;
}

.diary-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.diary-pet {
  font-size: 22rpx;
  color: var(--color-primary);
}

.diary-date {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.diary-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
