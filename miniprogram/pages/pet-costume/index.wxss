@import "../../styles/theme.wxss";

.page-costume {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 24rpx;
}

.costume-header {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.costume-pet {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.costume-pet-icon {
  font-size: 100rpx;
  margin-bottom: 12rpx;
}

.costume-pet-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.costume-sections {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.costume-section {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
  display: block;
}

.costume-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.costume-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.costume-item.equipped {
  border-color: var(--color-primary);
  background: rgba(91, 154, 111, 0.1);
}

.costume-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.costume-name {
  font-size: 20rpx;
  color: var(--color-text);
  text-align: center;
  margin-bottom: 4rpx;
}

.costume-status {
  font-size: 18rpx;
  color: var(--color-primary);
  font-weight: 600;
}
