@import "../../styles/theme.wxss";

.page-skill {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 24rpx;
}

.skill-header {
  margin-bottom: 32rpx;
}

.skill-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
  margin-bottom: 8rpx;
}

.skill-subtitle {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.skill-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skill-item {
  padding: 24rpx;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid transparent;
}

.skill-item.current {
  border-color: var(--color-primary);
  background: rgba(91, 154, 111, 0.05);
}

.skill-item.owned {
  opacity: 1;
}

.skill-item:not(.owned) {
  opacity: 0.6;
}

.skill-pet {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.skill-pet-icon {
  font-size: 40rpx;
}

.skill-pet-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.skill-badge {
  font-size: 20rpx;
  color: #fff;
  background: var(--color-primary);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.skill-info {
  padding-left: 52rpx;
}

.skill-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.skill-icon {
  font-size: 28rpx;
}

.skill-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.skill-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}
