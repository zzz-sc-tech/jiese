@import "../../styles/theme.wxss";

.page-achievement {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 24rpx;
}

.achievement-header {
  padding: 32rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.achievement-stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.achievement-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.achievement-count {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.achievement-progress {
  width: 100%;
}

.progress-track {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #fff;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.achievement-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.achievement-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  box-shadow: var(--shadow-sm);
}

.achievement-item.locked {
  opacity: 0.6;
}

.achievement-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.achievement-info {
  flex: 1;
}

.achievement-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 4rpx;
}

.achievement-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.achievement-status {
  font-size: 32rpx;
  flex-shrink: 0;
}

.status-locked {
  opacity: 0.5;
}
