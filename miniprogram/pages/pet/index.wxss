@import "../../styles/theme.wxss";

.page-pet {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* 无宠物状态 */
.no-pet {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.no-pet-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.no-pet-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.no-pet-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 48rpx;
}

.btn-adopt {
  width: 400rpx;
  height: 96rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  box-shadow: var(--shadow-lg);
}

.btn-adopt::after {
  display: none;
}

/* 有宠物状态 */
.pet-main {
  padding: 24rpx;
}

/* 宠物展示区 */
.pet-showcase {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
}

.pet-avatar {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-accent-light));
  border-radius: 50%;
  margin-bottom: 24rpx;
}

.pet-icon {
  font-size: 80rpx;
}

.pet-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.pet-stage {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
}

.exp-bar {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.exp-track {
  width: 80%;
  height: 16rpx;
  background: var(--color-border);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.exp-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.exp-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* 快捷操作 */
.pet-actions {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 48rpx;
  background: var(--color-bg-card);
  border-radius: 20rpx;
  box-shadow: var(--shadow-md);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--color-text);
}

/* 道具背包 */
.items-section {
  margin-bottom: 24rpx;
}

.items-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.item-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  box-shadow: var(--shadow-sm);
}

.item-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.item-count {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 4rpx;
}

.item-name {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  width: 100%;
  background: var(--color-bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text);
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg);
  border-radius: 50%;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.modal-body {
  margin-bottom: 32rpx;
}

.modal-footer {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 宠物选择网格 */
.pet-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.pet-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.pet-option.selected {
  border-color: var(--color-primary);
  background: rgba(91, 154, 111, 0.1);
}

.pet-option-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.pet-option-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 4rpx;
}

.pet-option-desc {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  text-align: center;
}

/* 道具选择网格 */
.feed-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.feed-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.feed-option.selected {
  border-color: var(--color-primary);
  background: rgba(91, 154, 111, 0.1);
}

.feed-option.disabled {
  opacity: 0.5;
}

.feed-option-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.feed-option-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 4rpx;
}

.feed-option-exp {
  font-size: 22rpx;
  color: var(--color-primary);
  margin-bottom: 4rpx;
}

.feed-option-count {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

/* 表单样式 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.btn-save {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  box-shadow: var(--shadow-lg);
}

.btn-save::after {
  display: none;
}

.btn-save[disabled] {
  opacity: 0.5;
}

/* 升级/进化弹窗 */
.levelup-modal {
  width: 80%;
  background: var(--color-bg-card);
  border-radius: 32rpx;
  overflow: hidden;
}

.levelup-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, rgba(232, 184, 109, 0.2), rgba(232, 184, 109, 0.1));
}

.levelup-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.levelup-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 24rpx;
}

.levelup-pet-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.levelup-pet-name {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.levelup-level {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.levelup-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
