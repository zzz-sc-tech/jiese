@import "../../styles/theme.wxss";

.page-pet {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* 宠物切换栏 */
.pet-tabs {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 16rpx;
  overflow-x: auto;
}

.pet-tab {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: var(--color-bg-card);
  border-radius: 32rpx;
  border: 2rpx solid transparent;
  box-shadow: var(--shadow-sm);
  flex-shrink: 0;
}

.pet-tab.active {
  border-color: var(--color-primary);
  background: rgba(91, 154, 111, 0.1);
}

.pet-tab.add {
  border: 2rpx dashed var(--color-border);
  background: transparent;
  box-shadow: none;
}

.pet-tab-icon {
  font-size: 32rpx;
}

.pet-tab-name {
  font-size: 24rpx;
  color: var(--color-text);
}

/* 添加宠物按钮 */
.add-pet-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  margin: 16rpx 24rpx;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  border: 2rpx dashed var(--color-border);
}

.add-pet-icon {
  font-size: 36rpx;
  color: var(--color-primary);
}

.add-pet-text {
  font-size: 26rpx;
  color: var(--color-primary);
}

/* 功能入口网格 */
.feature-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  box-shadow: var(--shadow-sm);
}

.feature-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.feature-name {
  font-size: 22rpx;
  color: var(--color-text);
}

/* 技能预览 */
.skill-preview {
  margin: 0 24rpx 24rpx;
  padding: 20rpx;
}

.skill-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.skill-icon {
  font-size: 32rpx;
}

.skill-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.skill-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 删除按钮 */
.delete-section {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.delete-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  border: 2rpx solid var(--color-danger);
}

.delete-text {
  font-size: 26rpx;
  color: var(--color-danger);
}

/* 无宠物状态 */
.no-pet {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.no-pet-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.no-pet-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.no-pet-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 48rpx;
}

.btn-adopt {
  width: 400rpx;
  height: 96rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  box-shadow: var(--shadow-lg);
}

.btn-adopt::after {
  display: none;
}

/* 有宠物状态 */
.pet-main {
  padding: 24rpx;
}

/* 宠物展示区 */
.pet-showcase {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

/* 宠物动画区域 */
.pet-animation-area {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

/* 宠物主体 */
.pet-body {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: petFloat 3s ease-in-out infinite;
  cursor: pointer;
}

.pet-body:active {
  transform: scale(0.95);
}

/* 宠物图标 */
.pet-main-icon {
  font-size: 160rpx;
  line-height: 1;
  filter: drop-shadow(0 8rpx 16rpx rgba(0,0,0,0.1));
}

/* 阴影 */
.pet-shadow {
  position: absolute;
  bottom: -20rpx;
  width: 120rpx;
  height: 20rpx;
  background: radial-gradient(ellipse, rgba(0,0,0,0.15) 0%, transparent 70%);
  border-radius: 50%;
  animation: shadowPulse 3s ease-in-out infinite;
}

/* 眼睛 */
.pet-eyes {
  display: none;
}

/* 气泡提示 */
.pet-bubble {
  position: absolute;
  top: -60rpx;
  left: 50%;
  transform: translateX(-50%) scale(0);
  background: var(--color-bg-card);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: var(--shadow-md);
  opacity: 0;
  transition: all 0.3s ease;
  white-space: nowrap;
  z-index: 10;
}

.pet-bubble.show {
  transform: translateX(-50%) scale(1);
  opacity: 1;
}

.pet-bubble::after {
  content: '';
  position: absolute;
  bottom: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 12rpx solid var(--color-bg-card);
}

.bubble-text {
  font-size: 24rpx;
  color: var(--color-text);
}

/* 爱心特效 */
.heart-effect {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 48rpx;
  opacity: 0;
  transform: scale(0) translateY(0);
  transition: all 0.5s ease;
}

.heart-effect.show {
  opacity: 1;
  transform: scale(1) translateY(-40rpx);
  animation: heartFloat 1s ease forwards;
}

/* 星星特效 */
.star-effects {
  position: absolute;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.star {
  position: absolute;
  font-size: 32rpx;
  opacity: 0;
}

.star1 {
  top: 0;
  left: 20rpx;
  animation: starBurst 0.8s ease forwards;
}

.star2 {
  top: 20rpx;
  right: 10rpx;
  animation: starBurst 0.8s ease 0.2s forwards;
}

.star3 {
  bottom: 40rpx;
  left: 40rpx;
  animation: starBurst 0.8s ease 0.4s forwards;
}

/* 宠物动画 */
@keyframes petFloat {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

@keyframes shadowPulse {
  0%, 100% {
    transform: scaleX(1);
    opacity: 1;
  }
  50% {
    transform: scaleX(0.8);
    opacity: 0.6;
  }
}

@keyframes heartFloat {
  0% {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
  100% {
    opacity: 0;
    transform: scale(1.5) translateY(-80rpx);
  }
}

@keyframes starBurst {
  0% {
    opacity: 0;
    transform: scale(0) rotate(0deg);
  }
  50% {
    opacity: 1;
    transform: scale(1.2) rotate(180deg);
  }
  100% {
    opacity: 0;
    transform: scale(0) rotate(360deg);
  }
}

/* 宠物动画状态 */
.pet-body.happy {
  animation: petHappy 0.5s ease;
}

.pet-body.eat {
  animation: petEat 0.3s ease;
}

.pet-body.sleep {
  animation: petSleep 2s ease-in-out infinite;
}

@keyframes petHappy {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25% { transform: translateY(-20rpx) rotate(-10deg); }
  75% { transform: translateY(-20rpx) rotate(10deg); }
}

@keyframes petEat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

@keyframes petSleep {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(10rpx); }
}

/* 心情指示 */
.pet-mood {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.mood-icon {
  font-size: 28rpx;
}

.mood-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.pet-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.pet-stage {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
}

.exp-bar {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.exp-track {
  width: 80%;
  height: 16rpx;
  background: var(--color-border);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.exp-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.exp-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* 快捷操作 */
.pet-actions {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 48rpx;
  background: var(--color-bg-card);
  border-radius: 20rpx;
  box-shadow: var(--shadow-md);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--color-text);
}

/* 道具背包 */
.items-section {
  margin-bottom: 24rpx;
}

.items-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.item-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  box-shadow: var(--shadow-sm);
}

.item-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.item-count {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 4rpx;
}

.item-name {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.items-empty {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.items-empty-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.feed-empty {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.feed-empty-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  width: 100%;
  background: var(--color-bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text);
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg);
  border-radius: 50%;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.modal-body {
  margin-bottom: 32rpx;
}

.modal-footer {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 宠物选择网格 */
.pet-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.pet-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.pet-option.selected {
  border-color: var(--color-primary);
  background: rgba(91, 154, 111, 0.1);
}

.pet-option-icon {
  font-size: 48rpx;
  margin-bottom: 4rpx;
}

.pet-option-name {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-text);
}

.pet-option-desc {
  font-size: 18rpx;
  color: var(--color-text-secondary);
  text-align: center;
}

/* 道具选择网格 */
.feed-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.feed-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.feed-option.selected {
  border-color: var(--color-primary);
  background: rgba(91, 154, 111, 0.1);
}

.feed-option.disabled {
  opacity: 0.5;
}

.feed-option-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.feed-option-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 4rpx;
}

.feed-option-exp {
  font-size: 22rpx;
  color: var(--color-primary);
  margin-bottom: 4rpx;
}

.feed-option-count {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

/* 表单样式 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.btn-save {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  box-shadow: var(--shadow-lg);
}

.btn-save::after {
  display: none;
}

.btn-save[disabled] {
  opacity: 0.5;
}

/* 升级/进化弹窗 */
.levelup-modal {
  width: 80%;
  background: var(--color-bg-card);
  border-radius: 32rpx;
  overflow: hidden;
}

.levelup-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, rgba(232, 184, 109, 0.2), rgba(232, 184, 109, 0.1));
}

.levelup-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.levelup-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 24rpx;
}

.levelup-pet-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.levelup-pet-name {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.levelup-level {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.levelup-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* 删除确认弹窗 */
.confirm-modal {
  width: 80%;
  background: var(--color-bg-card);
  border-radius: 32rpx;
  overflow: hidden;
}

.confirm-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
}

.confirm-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.confirm-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.confirm-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.confirm-actions {
  display: flex;
  border-top: 2rpx solid var(--color-border);
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  border-radius: 0;
  background: transparent;
}

.btn-cancel::after,
.btn-confirm::after {
  display: none;
}

.btn-cancel {
  color: var(--color-text-secondary);
  border-right: 2rpx solid var(--color-border);
}

.btn-confirm {
  color: var(--color-danger);
}
