<view class="page-pet {{themeClass}}">
  <!-- 无宠物状态 -->
  <view class="no-pet" wx:if="{{!hasPet}}">
    <view class="no-pet-icon">🐾</view>
    <text class="no-pet-title">还没有宠物</text>
    <text class="no-pet-desc">领养一只宠物，陪伴你自律成长</text>
    <button class="btn-adopt" bindtap="showAdoptModal">领养宠物</button>
  </view>

  <!-- 有宠物状态 -->
  <view class="pet-main" wx:if="{{hasPet && currentPet}}">
    <!-- 宠物切换栏 -->
    <view class="pet-tabs" wx:if="{{pets.length > 1}}">
      <view
        class="pet-tab {{currentPetIndex === index ? 'active' : ''}}"
        wx:for="{{pets}}"
        wx:key="petId"
        bindtap="switchPet"
        data-index="{{index}}"
      >
        <text class="pet-tab-icon">{{item.stageIcon}}</text>
        <text class="pet-tab-name">{{item.name}}</text>
      </view>
      <view class="pet-tab add" wx:if="{{pets.length < 2}}" bindtap="showAdoptModal">
        <text class="pet-tab-icon">+</text>
      </view>
    </view>

    <!-- 宠物展示区 -->
    <view class="pet-showcase card">
      <!-- 宠物动画区域 -->
      <view class="pet-animation-area">
        <!-- 气泡提示 -->
        <view class="pet-bubble {{showBubble ? 'show' : ''}}" wx:if="{{bubbleText}}">
          <text class="bubble-text">{{bubbleText}}</text>
        </view>

        <!-- 宠物主体 -->
        <view
          class="pet-body {{petAnimation}}"
          bindtap="onPetTap"
          bindlongpress="onPetLongPress"
        >
          <!-- 阴影 -->
          <view class="pet-shadow"></view>
          <!-- 宠物图标 -->
          <text class="pet-main-icon">{{currentPet.stageIcon}}</text>
        </view>

        <!-- 爱心特效 -->
        <view class="heart-effect {{showHeart ? 'show' : ''}}">❤️</view>

        <!-- 星星特效 -->
        <view class="star-effects" wx:if="{{showStars}}">
          <text class="star star1">✨</text>
          <text class="star star2">⭐</text>
          <text class="star star3">✨</text>
        </view>
      </view>

      <!-- 宠物信息 -->
      <text class="pet-name">{{currentPet.name}}</text>
      <text class="pet-stage">{{currentPet.stageName}} · Lv.{{currentPet.level}}</text>

      <!-- 心情指示 -->
      <view class="pet-mood">
        <text class="mood-icon">{{moodIcon}}</text>
        <text class="mood-text">{{moodText}}</text>
      </view>

      <!-- 经验条 -->
      <view class="exp-bar">
        <view class="exp-track">
          <view class="exp-fill" style="width: {{currentPet.levelProgress * 100}}%;"></view>
        </view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="pet-actions">
      <view class="action-btn" bindtap="showFeedModal">
        <text class="action-icon">🍖</text>
        <text class="action-text">投喂</text>
      </view>
      <view class="action-btn" bindtap="onPetPat">
        <text class="action-icon">🤚</text>
        <text class="action-text">摸摸</text>
      </view>
      <view class="action-btn" bindtap="goCostume" wx:if="{{pets.length > 0}}">
        <text class="action-icon">👗</text>
        <text class="action-text">装扮</text>
      </view>
      <view class="action-btn" bindtap="goBackground" wx:if="{{pets.length > 0}}">
        <text class="action-icon">🎨</text>
        <text class="action-text">背景</text>
      </view>
    </view>

    <!-- 只有一只宠物时显示添加按钮 -->
    <view class="add-pet-btn" wx:if="{{pets.length === 1}}" bindtap="showAdoptModal">
      <text class="add-pet-icon">+</text>
      <text class="add-pet-text">再养一只</text>
    </view>

    <!-- 功能入口 -->
    <view class="feature-grid">
      <view class="feature-item" bindtap="goDiary">
        <text class="feature-icon">📖</text>
        <text class="feature-name">宠物日记</text>
      </view>
      <view class="feature-item" bindtap="goAchievement">
        <text class="feature-icon">🏆</text>
        <text class="feature-name">宠物成就</text>
      </view>
      <view class="feature-item" bindtap="goSkill">
        <text class="feature-icon">✨</text>
        <text class="feature-name">宠物技能</text>
      </view>
      <view class="feature-item" bindtap="showInteract" wx:if="{{pets.length >= 2}}">
        <text class="feature-icon">💕</text>
        <text class="feature-name">宠物互动</text>
      </view>
    </view>

    <!-- 宠物技能预览 -->
    <view class="skills-section" wx:if="{{allSkills.length > 0}}">
      <view class="section-header">
        <text class="section-title">宠物技能</text>
      </view>
      <view class="skills-list">
        <view class="skill-item" wx:for="{{allSkills}}" wx:key="petId">
          <view class="skill-left">
            <text class="skill-icon">{{item.skill.icon}}</text>
            <view class="skill-info">
              <text class="skill-name">{{item.skill.name}}</text>
              <text class="skill-desc">{{item.skill.desc}}</text>
            </view>
          </view>
          <text class="skill-pet">{{item.petName}}</text>
        </view>
      </view>
    </view>

    <!-- 道具背包 -->
    <view class="items-section">
      <view class="section-header">
        <text class="section-title">道具背包</text>
      </view>
      <view class="items-grid" wx:if="{{hasItems}}">
        <view class="item-card" wx:for="{{items}}" wx:key="id" wx:if="{{item.count > 0}}">
          <text class="item-icon">{{item.icon}}</text>
          <text class="item-count">×{{item.count}}</text>
          <text class="item-name">{{item.name}}</text>
        </view>
      </view>
      <view class="items-empty" wx:if="{{!hasItems}}">
        <text class="items-empty-text">暂无道具</text>
      </view>
    </view>

    <!-- 放生按钮 -->
    <view class="delete-section" wx:if="{{pets.length > 1}}">
      <view class="delete-btn" bindtap="showDeleteConfirm">
        <text class="delete-text">放生宠物</text>
      </view>
    </view>
  </view>

  <!-- 领养弹窗 -->
  <view class="modal-overlay" wx:if="{{showAdopt}}" bindtap="hideAdoptModal">
    <view class="modal-content" catchtap>
      <view class="modal-header">
        <text class="modal-title">选择宠物</text>
        <view class="modal-close" bindtap="hideAdoptModal">
          <text>✕</text>
        </view>
      </view>

      <view class="modal-body">
        <view class="pet-grid">
          <view
            class="pet-option {{selectedPetId === item.id ? 'selected' : ''}}"
            wx:for="{{petTypes}}"
            wx:key="id"
            bindtap="selectPet"
            data-id="{{item.id}}"
          >
            <text class="pet-option-icon">{{item.icon}}</text>
            <text class="pet-option-name">{{item.name}}</text>
            <text class="pet-option-desc">{{item.desc}}</text>
          </view>
        </view>

        <view class="form-group" wx:if="{{selectedPetId}}">
          <text class="form-label">给宠物起个名字</text>
          <input
            class="form-input"
            placeholder="{{petTypes[selectedPetId].name}}"
            value="{{petName}}"
            bindinput="onPetNameInput"
            maxlength="8"
          />
        </view>
      </view>

      <view class="modal-footer">
        <button class="btn-save" bindtap="adoptPet" disabled="{{!selectedPetId}}">确认领养</button>
      </view>
    </view>
  </view>

  <!-- 投喂弹窗 -->
  <view class="modal-overlay" wx:if="{{showFeed}}" bindtap="hideFeedModal">
    <view class="modal-content" catchtap>
      <view class="modal-header">
        <text class="modal-title">投喂宠物</text>
        <view class="modal-close" bindtap="hideFeedModal">
          <text>✕</text>
        </view>
      </view>

      <view class="modal-body">
        <view class="feed-grid" wx:if="{{hasItems}}">
          <view
            class="feed-option {{selectedItemId === item.id ? 'selected' : ''}}"
            wx:for="{{items}}"
            wx:key="id"
            bindtap="selectItem"
            data-id="{{item.id}}"
            wx:if="{{item.count > 0}}"
          >
            <text class="feed-option-icon">{{item.icon}}</text>
            <text class="feed-option-name">{{item.name}}</text>
            <text class="feed-option-count">×{{item.count}}</text>
          </view>
        </view>
        <view class="feed-empty" wx:if="{{!hasItems}}">
          <text class="feed-empty-text">暂无道具，坚持打卡会获得哦~</text>
        </view>
      </view>

      <view class="modal-footer">
        <button class="btn-save" bindtap="feedPet" disabled="{{!selectedItemId}}">投喂</button>
      </view>
    </view>
  </view>

  <!-- 升级/进化提示 -->
  <view class="modal-overlay" wx:if="{{showLevelUp}}" bindtap="hideLevelUpModal">
    <view class="levelup-modal" catchtap>
      <view class="levelup-content">
        <text class="levelup-icon" wx:if="{{levelUpData.evolved}}">🎉</text>
        <text class="levelup-icon" wx:else>⬆️</text>
        <text class="levelup-title" wx:if="{{levelUpData.evolved}}">宠物进化！</text>
        <text class="levelup-title" wx:else>等级提升！</text>
        <text class="levelup-pet-icon">{{levelUpData.levelInfo.stageIcon}}</text>
        <text class="levelup-level">Lv.{{levelUpData.levelInfo.level}}</text>
      </view>
      <view class="levelup-footer">
        <button class="btn-save" bindtap="hideLevelUpModal">好的</button>
      </view>
    </view>
  </view>

  <!-- 删除确认弹窗 -->
  <view class="modal-overlay" wx:if="{{showDeleteConfirm}}" bindtap="hideDeleteConfirm">
    <view class="confirm-modal" catchtap>
      <view class="confirm-content">
        <text class="confirm-icon">😢</text>
        <text class="confirm-title">确定要放生吗？</text>
        <text class="confirm-desc">放生后将无法恢复</text>
      </view>
      <view class="confirm-actions">
        <button class="btn-cancel" bindtap="hideDeleteConfirm">取消</button>
        <button class="btn-confirm" bindtap="confirmDelete">确定放生</button>
      </view>
    </view>
  </view>

  <!-- 宠物互动弹窗 -->
  <view class="modal-overlay" wx:if="{{showInteractModal}}" bindtap="hideInteractModal">
    <view class="interact-modal" catchtap>
      <view class="interact-header">
        <text class="interact-title">宠物互动</text>
        <view class="modal-close" bindtap="hideInteractModal">
          <text>✕</text>
        </view>
      </view>
      <view class="interact-body">
        <view class="interact-pets">
          <text class="interact-pet-icon">{{pets[0].stageIcon}}</text>
          <text class="interact-heart">💕</text>
          <text class="interact-pet-icon">{{pets[1].stageIcon}}</text>
        </view>
        <view class="interact-result" wx:if="{{interactResult}}">
          <text class="interact-text">亲密度 +1</text>
        </view>
        <view class="interact-empty" wx:else>
          <text class="interact-hint">让两只宠物一起玩耍吧</text>
        </view>
      </view>
      <view class="interact-footer">
        <button class="btn-save" bindtap="doInteract">一起玩耍</button>
      </view>
    </view>
  </view>
</view>
