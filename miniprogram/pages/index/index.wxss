@import "../../styles/theme.wxss";

.page-index {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--color-primary-light) 0%, var(--color-bg) 40%, var(--color-bg) 100%);
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 600rpx;
  overflow: hidden;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.1;
}

.circle-1 {
  width: 400rpx;
  height: 400rpx;
  background: var(--color-primary);
  top: -100rpx;
  right: -100rpx;
  animation: float 8s ease-in-out infinite;
}

.circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: var(--color-primary-light);
  top: 50rpx;
  left: -80rpx;
  animation: float 6s ease-in-out infinite reverse;
}

.circle-3 {
  width: 200rpx;
  height: 200rpx;
  background: var(--color-accent);
  top: 200rpx;
  right: 50rpx;
  animation: float 10s ease-in-out infinite;
}

.bg-particle {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: var(--color-primary);
  border-radius: 50%;
  opacity: 0.3;
}

.particle-1 { top: 100rpx; left: 15%; animation: particleFloat 4s ease-in-out infinite; }
.particle-2 { top: 200rpx; right: 20%; animation: particleFloat 5s ease-in-out infinite 1s; }
.particle-3 { top: 350rpx; left: 30%; animation: particleFloat 6s ease-in-out infinite 2s; }
.particle-4 { top: 150rpx; right: 35%; animation: particleFloat 4.5s ease-in-out infinite 0.5s; }

/* 状态栏 */
.status-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(180deg, rgba(232, 245, 233, 0.95) 0%, rgba(232, 245, 233, 0) 100%);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.status-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  height: 44px;
}

.app-brand {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.app-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #5B9A6F, #8BC4A0);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(91, 154, 111, 0.3);
}

.app-icon-text {
  font-size: 32rpx;
  line-height: 1;
}

.app-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E2D;
}

.today-date {
  background: rgba(91, 154, 111, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.date-text {
  font-size: 24rpx;
  color: #5B9A6F;
}

/* 主内容 */
.main-content {
  padding: 0 32rpx;
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
  position: relative;
  z-index: 1;
}

/* 总览卡片 */
.overview-card {
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #5B9A6F, #8BC4A0);
  color: #fff;
  padding: 32rpx 24rpx;
}

.overview-main {
  text-align: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.2);
}

.overview-highlight {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
}

.highlight-value {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1;
}

.highlight-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.overview-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-value {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
}

.overview-label {
  font-size: 22rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.overview-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 语录预览 */
.quote-preview {
  margin-bottom: 30rpx;
  transition: transform 0.2s ease;
}

.quote-preview:active {
  transform: scale(0.98);
}

.quote-preview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.preview-label {
  font-size: 24rpx;
  color: #5B9A6F;
  font-weight: 600;
  background: rgba(91, 154, 111, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
}

.preview-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.preview-text {
  font-size: 28rpx;
  color: #2C3E2D;
  line-height: 1.8;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.preview-author {
  font-size: 24rpx;
  color: #7A8F7C;
  text-align: right;
  margin-top: 12rpx;
  display: block;
}

/* 目标区域 */
.goals-section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E2D;
}

.add-goal-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(91, 154, 111, 0.1);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
}

.add-icon {
  font-size: 28rpx;
  color: #5B9A6F;
  font-weight: 700;
}

.add-text {
  font-size: 24rpx;
  color: #5B9A6F;
  font-weight: 500;
}

/* 空状态 */
.goals-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(91, 154, 111, 0.08);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #2C3E2D;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #7A8F7C;
}

/* 目标卡片 */
.goal-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.3s ease;
}

.goal-card.checked {
  background: linear-gradient(135deg, rgba(91, 154, 111, 0.05), rgba(139, 196, 160, 0.08));
}

.goal-card:active {
  transform: scale(0.98);
}

.goal-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.goal-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.goal-icon {
  font-size: 44rpx;
}

.goal-info {
  flex: 1;
}

.goal-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E2D;
  display: block;
  margin-bottom: 6rpx;
}

.goal-stats-row {
  display: flex;
  gap: 16rpx;
}

.goal-streak {
  font-size: 22rpx;
  color: #5B9A6F;
  background: rgba(91, 154, 111, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.goal-total {
  font-size: 22rpx;
  color: #7A8F7C;
}

.goal-right {
  flex-shrink: 0;
  margin-left: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.goal-edit-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.04);
}

.edit-dots {
  font-size: 32rpx;
  color: #999;
  letter-spacing: -4rpx;
}

.goal-check-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.goal-check-btn.done {
  animation: checkBounce 0.4s ease;
}

.check-icon {
  font-size: 32rpx;
  font-weight: 700;
  color: #999;
}

/* 快捷入口 */
.shortcuts {
  display: flex;
  justify-content: center;
  gap: 60rpx;
}

.shortcut-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 0.2s ease;
}

.shortcut-item:active {
  transform: scale(0.9);
}

.shortcut-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.shortcut-text {
  font-size: 24rpx;
  color: #7A8F7C;
}

/* 添加目标弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-overlay[hidden] {
  display: none;
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2C3E2D;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  font-size: 28rpx;
  color: #999;
}

.modal-body {
  margin-bottom: 40rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 26rpx;
  color: #7A8F7C;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F5F9F7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #2C3E2D;
  box-sizing: border-box;
}

.icon-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.icon-option {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  transition: all 0.2s ease;
}

.icon-option.selected {
  transform: scale(1.1);
}

.icon-emoji {
  font-size: 40rpx;
}

/* 目标类型选择器 */
.type-selector {
  display: flex;
  gap: 16rpx;
}

.type-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  border-radius: 16rpx;
  background: #F5F9F7;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.type-option.selected {
  border-color: #5B9A6F;
  background: rgba(91, 154, 111, 0.08);
}

.type-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.type-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #2C3E2D;
  margin-bottom: 4rpx;
}

.type-desc {
  font-size: 20rpx;
  color: #7A8F7C;
}

/* 计时器入口按钮 */
.goal-timer-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.goal-timer-btn:active {
  transform: scale(0.9);
}

.timer-icon {
  font-size: 28rpx;
}

.btn-save {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #5B9A6F, #8BC4A0);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(91, 154, 111, 0.3);
}

.btn-save::after {
  display: none;
}

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(5deg); }
}

@keyframes particleFloat {
  0%, 100% { transform: translateY(0) scale(1); opacity: 0.3; }
  50% { transform: translateY(-30rpx) scale(1.5); opacity: 0.6; }
}

@keyframes checkBounce {
  0% { transform: scale(0.8); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

/* 报告弹窗 */
.report-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.report-overlay[hidden] {
  display: none;
}

.report-modal {
  width: 85%;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.report-modal-lg {
  width: 90%;
  max-height: 85vh;
}

.report-header {
  padding: 32rpx;
  background: linear-gradient(135deg, #5B9A6F, #8BC4A0);
  color: #fff;
  text-align: center;
}

.report-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.report-date {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
  display: block;
}

.report-scroll {
  flex: 1;
  max-height: 60vh;
}

.report-body {
  padding: 32rpx;
}

.report-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #f0f0f0;
}

.btn-report-close {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #5B9A6F, #8BC4A0);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 20rpx;
  border: none;
}

.btn-report-close::after {
  display: none;
}

/* 昨日总结 */
.yesterday-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.score-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.score-inner {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #5B9A6F;
}

.score-label {
  font-size: 20rpx;
  color: #7A8F7C;
}

.score-text {
  font-size: 28rpx;
  color: #2C3E2D;
  font-weight: 500;
}

.yesterday-goals {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.yesterday-goal-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #F5F9F7;
  border-radius: 16rpx;
}

.yg-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.yg-name {
  flex: 1;
  font-size: 28rpx;
  color: #2C3E2D;
}

.yg-status {
  font-size: 24rpx;
  font-weight: 500;
}

.yg-status.done {
  color: #5B9A6F;
}

.yg-status.miss {
  color: #E88D67;
}

/* 周报 */
.weekly-overview {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.wo-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wo-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #5B9A6F;
}

.wo-label {
  font-size: 22rpx;
  color: #7A8F7C;
  margin-top: 4rpx;
}

.chart-section {
  margin-bottom: 32rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E2D;
  margin-bottom: 20rpx;
  display: block;
}

/* 目标打卡图表 */
.goal-chart {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: #F5F9F7;
  border-radius: 16rpx;
}

.gc-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.gc-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.gc-name {
  flex: 1;
  font-size: 26rpx;
  color: #2C3E2D;
  font-weight: 500;
}

.gc-rate {
  font-size: 26rpx;
  color: #5B9A6F;
  font-weight: 600;
}

.gc-bars {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 100rpx;
  margin-bottom: 8rpx;
}

.gc-bar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  height: 100%;
  justify-content: flex-end;
}

.gc-bar {
  width: 32rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: #E8F5E9;
  transition: height 0.3s ease;
}

.gc-bar.active {
  background: linear-gradient(180deg, #5B9A6F, #8BC4A0);
}

.gc-day-label {
  font-size: 18rpx;
  color: #999;
  margin-top: 6rpx;
}

.gc-streak {
  font-size: 22rpx;
  color: #7A8F7C;
  text-align: center;
}

/* 时间分析 */
.time-chart {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: #F5F9F7;
  border-radius: 16rpx;
}

.tc-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tc-icon {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.tc-name {
  font-size: 26rpx;
  color: #2C3E2D;
  font-weight: 500;
}

.tc-pattern {
  font-size: 22rpx;
  color: #5B9A6F;
  background: rgba(91, 154, 111, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.tc-timeline {
  margin-bottom: 16rpx;
}

.tc-axis {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.tc-axis-label {
  font-size: 18rpx;
  color: #999;
}

.tc-track {
  position: relative;
  height: 60rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: visible;
}

.tc-zone {
  position: absolute;
  top: 0;
  height: 100%;
  opacity: 0.15;
}

.z-night { background: #6B8DD6; }
.z-morning { background: #E8B86D; }
.z-forenoon { background: #5B9A6F; }
.z-noon { background: #E88D67; }
.z-afternoon { background: #5BAEBF; }
.z-evening { background: #9B72CF; }
.z-latenight { background: #6B8DD6; }

.tc-point {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #E8F5E9;
  z-index: 2;
}

.tc-point.active {
  background: #5B9A6F;
  box-shadow: 0 0 0 6rpx rgba(91, 154, 111, 0.25);
  width: 24rpx;
  height: 24rpx;
}

.tc-point-tooltip {
  position: absolute;
  bottom: calc(100% + 12rpx);
  left: 50%;
  transform: translateX(-50%);
  background: #2C3E2D;
  color: #fff;
  padding: 8rpx 14rpx;
  border-radius: 10rpx;
  white-space: nowrap;
  display: none;
  flex-direction: column;
  align-items: center;
  font-size: 20rpx;
  z-index: 10;
}

.tc-point.active:active .tc-point-tooltip {
  display: flex;
}

.tc-tooltip-date {
  font-size: 18rpx;
  opacity: 0.7;
}

.tc-tooltip-time {
  font-size: 26rpx;
  font-weight: 600;
}

.tc-tooltip-period {
  font-size: 18rpx;
  color: #8BC4A0;
}

.period-bar {
  display: flex;
  height: 48rpx;
  border-radius: 12rpx;
  overflow: hidden;
  gap: 2rpx;
}

.period-segment {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  transition: all 0.3s ease;
}

.period-segment:nth-child(1) { background: rgba(107, 141, 214, 0.6); }
.period-segment:nth-child(2) { background: rgba(232, 184, 109, 0.6); }
.period-segment:nth-child(3) { background: rgba(91, 154, 111, 0.6); }
.period-segment:nth-child(4) { background: rgba(232, 141, 103, 0.6); }
.period-segment:nth-child(5) { background: rgba(91, 174, 191, 0.6); }
.period-segment:nth-child(6) { background: rgba(155, 114, 207, 0.6); }
.period-segment:nth-child(7) { background: rgba(107, 141, 214, 0.4); }

.period-segment.highlight {
  box-shadow: 0 0 0 3rpx rgba(91, 154, 111, 0.5);
}

.period-seg-text {
  font-size: 18rpx;
  color: #fff;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 挑战进度 */
.challenge-progress-item {
  margin-bottom: 16rpx;
  padding: 16rpx;
  background: #F5F9F7;
  border-radius: 16rpx;
}

.cp-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.cp-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.cp-name {
  flex: 1;
  font-size: 24rpx;
  color: #2C3E2D;
}

.cp-progress {
  font-size: 24rpx;
  color: #5B9A6F;
  font-weight: 600;
}

.cp-bar {
  height: 12rpx;
  background: #E8F5E9;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.cp-fill {
  height: 100%;
  background: linear-gradient(90deg, #5B9A6F, #8BC4A0);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.cp-detail {
  font-size: 22rpx;
  color: #7A8F7C;
}

/* 数据分析 */
.analysis-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.analysis-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 16rpx;
  background: #F5F9F7;
  border-radius: 16rpx;
}

.analysis-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.analysis-text {
  font-size: 26rpx;
  color: #2C3E2D;
  line-height: 1.6;
}
