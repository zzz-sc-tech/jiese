/* 清新治愈风主题变量 */
page {
  --color-primary: #5B9A6F;
  --color-primary-light: #8BC4A0;
  --color-primary-dark: #3D7A50;
  --color-bg: #F5F9F7;
  --color-bg-card: #FFFFFF;
  --color-accent: #E8B86D;
  --color-accent-light: #F5D89A;
  --color-text: #2C3E2D;
  --color-text-secondary: #7A8F7C;
  --color-text-light: #A8BFA9;
  --color-border: #E0EDE2;
  --color-danger: #E87461;
  --color-success: #5B9A6F;

  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 40rpx;
  --radius-round: 50%;

  --shadow-sm: 0 2rpx 8rpx rgba(91, 154, 111, 0.08);
  --shadow-md: 0 4rpx 16rpx rgba(91, 154, 111, 0.12);
  --shadow-lg: 0 8rpx 32rpx rgba(91, 154, 111, 0.16);
  --shadow-xl: 0 16rpx 48rpx rgba(91, 154, 111, 0.2);

  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-xxl: 48rpx;
  --font-display: 72rpx;
  --font-hero: 120rpx;

  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-xxl: 64rpx;

  --transition-fast: 0.2s ease;
  --transition-normal: 0.3s ease;
  --transition-slow: 0.5s ease;
  --transition-spring: 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 裸粉主题 - 支持 page 和 view 元素 */
page.theme-pink,
.theme-pink {
  --color-primary: #C4A0A0;
  --color-primary-light: #D8BCBC;
  --color-primary-dark: #B08888;
  --color-bg: #FAF6F6;
  --color-bg-card: #FFFFFF;
  --color-accent: #C8B8A8;
  --color-accent-light: #DCD0C4;
  --color-text: #4A3E3E;
  --color-text-secondary: #8A7A7A;
  --color-text-light: #B8A8A8;
  --color-border: #E8DCDC;
  --color-danger: #E87461;
  --color-success: #C4A0A0;

  --shadow-sm: 0 2rpx 8rpx rgba(196, 160, 160, 0.08);
  --shadow-md: 0 4rpx 16rpx rgba(196, 160, 160, 0.12);
  --shadow-lg: 0 8rpx 32rpx rgba(196, 160, 160, 0.16);
  --shadow-xl: 0 16rpx 48rpx rgba(196, 160, 160, 0.2);
}
